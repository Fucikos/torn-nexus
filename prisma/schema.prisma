// prisma/schema.prisma
// Run: npx prisma migrate deploy

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
//  USERS
// ─────────────────────────────────────────────
model User {
  id           Int      @id @default(autoincrement())
  tornId       Int      @unique @map("torn_id")
  username     String   @unique @db.VarChar(64)
  encryptedKey String   @map("encrypted_key") @db.Text // AES-256 encrypted limited API key
  createdAt    DateTime @default(now()) @map("created_at")
  lastSeen     DateTime @default(now()) @map("last_seen")

  wallet       Wallet?
  bets         Bet[]
  transactions Transaction[]

  @@map("users")
}

// ─────────────────────────────────────────────
//  WALLETS  (one per user)
// ─────────────────────────────────────────────
model Wallet {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique @map("user_id")
  balance        BigInt   @default(0)         // Torn $ — stored as integer to avoid float bugs
  totalDeposited BigInt   @default(0) @map("total_deposited")
  totalWithdrawn BigInt   @default(0) @map("total_withdrawn")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id])

  @@map("wallets")
}

// ─────────────────────────────────────────────
//  TRANSACTIONS  (full ledger)
// ─────────────────────────────────────────────
model Transaction {
  id          Int               @id @default(autoincrement())
  userId      Int               @map("user_id")
  type        TransactionType
  amount      BigInt                            // always positive
  description String?           @db.Text
  tornTxId    Int?              @unique @map("torn_tx_id") // prevents double-crediting
  roundId     Int?              @map("round_id")
  status      TransactionStatus @default(COMPLETED)
  createdAt   DateTime          @default(now()) @map("created_at")

  user        User              @relation(fields: [userId], references: [id])
  round       Round?            @relation(fields: [roundId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_WIN
  BET_LOSS

  @@map("transaction_type")
}

enum TransactionStatus {
  COMPLETED
  PENDING    // withdrawals waiting for manual fulfillment
  FAILED

  @@map("transaction_status")
}

// ─────────────────────────────────────────────
//  ROUNDS  (each crash game round)
// ─────────────────────────────────────────────
model Round {
  id          Int       @id @default(autoincrement())
  crashPoint  Decimal   @map("crash_point") @db.Decimal(10, 2)
  seed        String    @db.Text           // published after round ends for provably fair
  phase       RoundPhase @default(BETTING)
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")

  bets         Bet[]
  transactions Transaction[]

  @@map("rounds")
}

enum RoundPhase {
  BETTING
  RUNNING
  CRASHED

  @@map("round_phase")
}

// ─────────────────────────────────────────────
//  BETS  (one per player per round)
// ─────────────────────────────────────────────
model Bet {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  roundId      Int      @map("round_id")
  amount       BigInt
  cashoutMult  Decimal? @map("cashout_mult") @db.Decimal(10, 2) // NULL = busted
  payout       BigInt   @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id])
  round        Round    @relation(fields: [roundId], references: [id])

  @@unique([userId, roundId]) // one bet per player per round
  @@map("bets")
}

// ─────────────────────────────────────────────
//  GAME STATE  (single row — the live round)
// ─────────────────────────────────────────────
// The game-server updates this row every tick.
// Vercel API routes read it to serve clients.
model GameState {
  id          Int        @id @default(1)    // always row 1
  roundId     Int        @map("round_id")
  phase       RoundPhase @default(BETTING)
  multiplier  Decimal    @default(1.00) @db.Decimal(10, 2)
  phaseEndsAt DateTime   @map("phase_ends_at") // when betting/cooldown ends
  updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at")

  @@map("game_state")
}
