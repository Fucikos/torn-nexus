generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  tornId       Int      @unique @map("torn_id")
  username     String   @unique @db.VarChar(64)
  encryptedKey String   @map("encrypted_key") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  lastSeen     DateTime @default(now()) @map("last_seen")

  wallet       Wallet?
  bets         Bet[]
  transactions Transaction[]

  @@map("users")
}

model Wallet {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique @map("user_id")
  balance        BigInt   @default(0)
  totalDeposited BigInt   @default(0) @map("total_deposited")
  totalWithdrawn BigInt   @default(0) @map("total_withdrawn")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model Transaction {
  id          Int               @id @default(autoincrement())
  userId      Int               @map("user_id")
  type        TransactionType
  amount      BigInt
  description String?           @db.Text
  tornTxKey   String?           @unique @map("torn_tx_key") @db.Text
  roundId     Int?              @map("round_id")
  status      TransactionStatus @default(COMPLETED)
  createdAt   DateTime          @default(now()) @map("created_at")

  user        User              @relation(fields: [userId], references: [id])
  round       Round?            @relation(fields: [roundId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_WIN
  BET_LOSS

  @@map("transaction_type")
}

enum TransactionStatus {
  COMPLETED
  PENDING
  FAILED

  @@map("transaction_status")
}

model Round {
  id         Int        @id @default(autoincrement())
  crashPoint Decimal    @map("crash_point") @db.Decimal(10, 2)
  seed       String     @db.Text
  phase      RoundPhase @default(BETTING)
  startedAt  DateTime   @default(now()) @map("started_at")
  endedAt    DateTime?  @map("ended_at")

  bets         Bet[]
  transactions Transaction[]

  @@map("rounds")
}

// COOLDOWN is used on GameState only (between rounds).
// Round rows never use COOLDOWN — they go BETTING → RUNNING → CRASHED.
enum RoundPhase {
  COOLDOWN
  BETTING
  RUNNING
  CRASHED

  @@map("round_phase")
}

model Bet {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  roundId     Int      @map("round_id")
  amount      BigInt
  cashoutMult Decimal? @map("cashout_mult") @db.Decimal(10, 2)
  payout      BigInt   @default(0)
  fee         BigInt   @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id])
  round       Round    @relation(fields: [roundId], references: [id])

  @@unique([userId, roundId])
  @@map("bets")
}

model GameState {
  id               Int        @id @default(1)
  roundId          Int        @map("round_id")
  phase            RoundPhase @default(COOLDOWN)
  multiplier       Decimal    @default(1.00) @db.Decimal(10, 4)
  phaseEndsAt      DateTime   @map("phase_ends_at")
  runningStartedAt DateTime?  @map("running_started_at")
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at")

  @@map("game_state")
}
