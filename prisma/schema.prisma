generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  tornId       Int      @unique @map("torn_id")
  username     String   @unique @db.VarChar(64)
  encryptedKey String   @map("encrypted_key") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  lastSeen     DateTime @default(now()) @map("last_seen")

  wallet       Wallet?
  games        Game[]
  transactions Transaction[]

  @@map("users")
}

model Wallet {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique @map("user_id")
  balance        BigInt   @default(0)
  totalDeposited BigInt   @default(0) @map("total_deposited")
  totalWithdrawn BigInt   @default(0) @map("total_withdrawn")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model Transaction {
  id          Int               @id @default(autoincrement())
  userId      Int               @map("user_id")
  type        TransactionType
  amount      BigInt
  description String?           @db.Text
  tornTxKey   String?           @unique @map("torn_tx_key") @db.Text
  gameId      Int?              @map("game_id")
  status      TransactionStatus @default(COMPLETED)
  createdAt   DateTime          @default(now()) @map("created_at")

  user        User              @relation(fields: [userId], references: [id])
  game        Game?             @relation(fields: [gameId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_WIN
  BET_LOSS

  @@map("transaction_type")
}

enum TransactionStatus {
  COMPLETED
  PENDING
  FAILED

  @@map("transaction_status")
}

// One Game = one full crossing attempt by one player
model Game {
  id           Int        @id @default(autoincrement())
  userId       Int        @map("user_id")
  betAmount    BigInt     @map("bet_amount")
  // Seed used server-side to pre-determine all 8 outcomes (never sent to client)
  seed         String     @db.Text
  // How many steps the chicken successfully crossed (0-8)
  stepsReached Int        @default(0) @map("steps_reached")
  // cashoutMult null = game still active OR busted; set on cashout
  cashoutMult  Decimal?   @map("cashout_mult") @db.Decimal(10, 4)
  payout       BigInt     @default(0)
  fee          BigInt     @default(0)
  status       GameStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  endedAt      DateTime?  @map("ended_at")

  user         User       @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@map("games")
}

enum GameStatus {
  ACTIVE
  CASHED_OUT
  BUSTED

  @@map("game_status")
}
