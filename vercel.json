{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "client",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^/$",
      "dest": "/client/index.html"
    },
    {
      "src": "^/admin$",
      "dest": "/client/admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ]
}